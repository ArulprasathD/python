   "source": [
    "def even(num):\n",
    "\n",
    "    even_count = 0\n",
    "    \n",
    "    for i in str(num):\n",
    "        if int(i) % 2 == 0:\n",
    "            even_count += 1\n",
    "\n",
    "    return even_count\n",
    "\n",
    "num = int(input(\"Enter the number : \"))\n",
    "print(\"Even count : \",even(num))"
   ]
